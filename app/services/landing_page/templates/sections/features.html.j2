<section class="features" id="features" data-section="features">
    <div class="features__container">
        <h2 class="features__heading">Why {{ product_name }}</h2>
        <div class="features__grid">
            {% for feature in features %}
            <div class="features__card">
                <div class="features__stat">{{ feature.stat }}</div>
                <h3 class="features__title">{{ feature.title }}</h3>
                <p class="features__description">{{ feature.description }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<style>
.features {
    padding: 4rem 1rem;
    background-color: var(--color-primary);
    color: white;
}

.features__container {
    max-width: 1200px;
    margin: 0 auto;
}

.features__heading {
    text-align: center;
    margin-bottom: 3rem;
    color: white;
    font-size: 2rem;
}

.features__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
}

.features__card {
    padding: 2rem;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    text-align: center;
    backdrop-filter: blur(4px);
}

.features__stat {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    line-height: 1;
}

.features__title {
    color: white;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
}

.features__description {
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    margin: 0;
}

@media (min-width: 768px) {
    .features__grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (min-width: 1024px) {
    .features {
        padding: 5rem 2rem;
    }
    .features__grid {
        grid-template-columns: repeat(3, 1fr);
    }
}
</style>
