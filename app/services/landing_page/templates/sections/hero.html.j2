<section class="hero" id="hero" data-section="hero">
    <div class="hero__container">
        <div class="hero__content">
            <h1 class="hero__headline">{{ headline }}</h1>
            <p class="hero__subheadline">{{ subheadline }}</p>
            <div class="hero__cta-group">
                <a href="#waitlist" class="hero__cta">{{ cta_text }}</a>
                {% if trust_text %}
                <p class="hero__trust">{{ trust_text }}</p>
                {% endif %}
            </div>
        </div>
        <div class="hero__media">
            {% if video_url %}
            <video class="hero__video" autoplay muted loop playsinline poster="{{ hero_image }}">
                <source src="{{ video_url }}" type="video/mp4">
                Your browser does not support the video tag.
            </video>
            {% elif hero_image %}
            <img src="{{ hero_image }}" alt="{{ headline }}" class="hero__image" loading="eager">
            {% endif %}
        </div>
    </div>
</section>

<style>
.hero {
    padding: 3rem 1rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    color: white;
    min-height: 80vh;
    display: flex;
    align-items: center;
}

.hero__container {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
}

.hero__content {
    text-align: center;
}

.hero__headline {
    font-size: 2.25rem;
    margin-bottom: 1rem;
    color: white;
    line-height: 1.15;
    letter-spacing: -0.02em;
}

.hero__subheadline {
    font-size: 1.15rem;
    margin-bottom: 2rem;
    opacity: 0.92;
    line-height: 1.6;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
}

.hero__cta-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
}

.hero__cta {
    display: inline-block;
    min-height: 48px;
    min-width: 200px;
    padding: 16px 36px;
    font-size: 18px;
    font-weight: 700;
    color: var(--color-primary);
    background-color: white;
    border: none;
    border-radius: 8px;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    text-align: center;
}

.hero__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
}

.hero__cta:active {
    transform: translateY(0);
}

.hero__trust {
    font-size: 0.8rem;
    opacity: 0.75;
    margin: 0;
}

.hero__media {
    width: 100%;
    max-width: 500px;
}

.hero__video,
.hero__image {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
}

/* Tablet: start split layout */
@media (min-width: 768px) {
    .hero {
        padding: 4rem 2rem;
    }

    .hero__container {
        flex-direction: row;
        gap: 3rem;
    }

    .hero__content {
        flex: 1;
        text-align: left;
    }

    .hero__headline {
        font-size: 2.75rem;
    }

    .hero__subheadline {
        font-size: 1.25rem;
        margin-left: 0;
        margin-right: 0;
    }

    .hero__cta-group {
        align-items: flex-start;
    }

    .hero__media {
        flex: 1;
        max-width: 50%;
    }
}

/* Desktop */
@media (min-width: 1024px) {
    .hero {
        padding: 5rem 3rem;
    }

    .hero__headline {
        font-size: 3.25rem;
    }

    .hero__subheadline {
        font-size: 1.35rem;
    }
}
</style>
