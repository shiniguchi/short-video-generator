<section class="benefits" id="benefits" data-section="benefits">
    <div class="benefits__container">
        <h2 class="benefits__heading">{{ heading }}</h2>
        <div class="benefits__grid">
            {% for benefit in benefits %}
            <div class="benefits__card stagger-item">
                {% if benefit.image %}
                <div class="benefits__image-wrap">
                    <img src="{{ benefit.image }}" alt="{{ benefit.title }}" class="benefits__image" loading="lazy">
                </div>
                {% endif %}
                <div class="benefits__body">
                    <div class="benefits__icon">{{ benefit.icon_emoji }}</div>
                    <h3 class="benefits__title">{{ benefit.title }}</h3>
                    <p class="benefits__description">{{ benefit.description }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

<style>
.benefits {
    padding: 3rem 1rem;
    background-color: var(--color-bg);
}

.benefits__container {
    max-width: 1200px;
    margin: 0 auto;
}

.benefits__heading {
    text-align: center;
    color: var(--color-text);
    margin-bottom: 2.5rem;
    font-size: 2rem;
}

.benefits__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
}

.benefits__card {
    background-color: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
}

.benefits__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
}

.benefits__image-wrap {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
}

.benefits__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.benefits__body {
    padding: 1.5rem;
    text-align: center;
}

.benefits__icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
    transition: transform 0.3s ease;
}
.benefits__card:hover .benefits__icon {
    transform: scale(1.15);
}
.benefits__card:hover .benefits__image {
    transform: scale(1.05);
}
.benefits__image {
    transition: transform 0.4s ease;
}

.benefits__title {
    color: var(--color-primary);
    margin-bottom: 0.5rem;
}

.benefits__description {
    color: #666;
    line-height: 1.6;
}

/* Tablet: 2 columns */
@media (min-width: 768px) {
    .benefits__grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

/* Desktop: 3 columns */
@media (min-width: 1024px) {
    .benefits {
        padding: 4rem 2rem;
    }

    .benefits__grid {
        grid-template-columns: repeat(3, 1fr);
    }
}
</style>
